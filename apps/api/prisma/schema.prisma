generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id              String           @id @default(cuid())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tickets         Ticket[]
  ticketPipelines TicketPipeline[]
  users           User[]
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  password        String
  role            Role
  departmentId    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]
  assignedTickets Ticket[]      @relation("TicketAssignee")
  createdTickets  Ticket[]      @relation("TicketCreator")
  department      Department?   @relation(fields: [departmentId], references: [id])
}

model TicketType {
  id          String           @id @default(cuid())
  name        String           @unique
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tickets     Ticket[]
  pipeline    TicketPipeline[]
}

model Ticket {
  id                  String        @id @default(cuid())
  title               String
  description         String
  status              TicketStatus  @default(OPEN)
  ticketTypeId        String
  createdById         String
  assignedToId        String?
  currentDepartmentId String
  resolvedAt          DateTime?
  closedAt            DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  pipelineStep        Int           @default(1)
  latestRemark        String?
  activities          ActivityLog[]
  assignedTo          User?         @relation("TicketAssignee", fields: [assignedToId], references: [id])
  createdBy           User          @relation("TicketCreator", fields: [createdById], references: [id])
  currentDepartment   Department    @relation(fields: [currentDepartmentId], references: [id])
  ticketType          TicketType    @relation(fields: [ticketTypeId], references: [id])
}

model ActivityLog {
  id             String       @id @default(cuid())
  ticketId       String
  userId         String
  type           ActivityType
  message        String?
  userMessage    String?
  assignedFromId String?
  assignedToId   String?
  createdAt      DateTime     @default(now())
  ticket         Ticket       @relation(fields: [ticketId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model TicketPipeline {
  id           String     @id @default(cuid())
  ticketTypeId String
  departmentId String
  order        Int
  department   Department @relation(fields: [departmentId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
}

enum Role {
  END_USER
  DEPARTMENT_MEMBER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum ActivityType {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  ESCALATED
}
